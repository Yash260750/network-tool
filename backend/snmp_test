import asyncio
import warnings

# Suppress cryptography deprecation warnings in terminal output
warnings.filterwarnings("ignore", category=DeprecationWarning)
warnings.filterwarnings("ignore", category=UserWarning)

from pysnmp.hlapi.asyncio import (
    SnmpEngine,
    UsmUserData,
    UdpTransportTarget,
    ContextData,
    ObjectType,
    ObjectIdentity,
    get_cmd,
    # Authentication protocol
    usmHMACSHAAuthProtocol,       # SHA-1
    # Privacy / Encryption protocol
    usmAesCfb128Protocol,         # AES-128
)

async def snmpv3_get():
    # --- Device Configuration ---
    target_ip = "192.168.11.245"
    target_port = 161
    username = "netmap-ro"
    
    # Passphrases (Must be >= 8 characters)
    auth_key = "Saket987654"  # Replace with the new 8+ char password
    priv_key = "Bander@786"

    # --- Setup Async Transport Target ---
    transport_target = await UdpTransportTarget.create(
        (target_ip, target_port), 
        timeout=2.0, 
        retries=1
    )

    # --- Execute SNMP GET Request ---
    # sysDescr OID: .1.3.6.1.2.1.1.1.0
    errorIndication, errorStatus, errorIndex, varBinds = await get_cmd(
        SnmpEngine(),
        UsmUserData(
            userName=username,
            authKey=auth_key,
            authProtocol=usmHMACSHAAuthProtocol,
            privKey=priv_key,
            privProtocol=usmAesCfb128Protocol
        ),
        transport_target,
        ContextData(),
        ObjectType(ObjectIdentity("1.3.6.1.2.1.1.1.0"))
    )

    # --- Handle Response ---
    if errorIndication:
        print(f"Network / Engine Error: {errorIndication}")
    elif errorStatus:
        print(f"SNMP Error: {errorStatus.prettyPrint()} at index {errorIndex}")
    else:
        for varBind in varBinds:
            print(f"{varBind[0].prettyPrint()} = {varBind[1].prettyPrint()}")

if __name__ == "__main__":
    asyncio.run(snmpv3_get())